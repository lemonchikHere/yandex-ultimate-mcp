# Universal token used by several modules when service-specific token is absent
YANDEX_TOKEN=

# Direct / Metrika / Wordstat mega-pack (@stegyan/yandex-mcp)
YANDEX_DIRECT_TOKEN=
YANDEX_METRIKA_TOKEN=
YANDEX_CLIENT_LOGIN=
YANDEX_USE_SANDBOX=0

# Webmaster (weselow/yandex-webmaster-mcp-server)
YANDEX_WEBMASTER_OAUTH_TOKEN=
YANDEX_WEBMASTER_HOST_URL=

# Tracker
YANDEX_TRACKER_TOKEN=
YANDEX_TRACKER_ORG_ID=

# Yandex Cloud / Search
YC_OAUTH_TOKEN=
YC_CLOUD_ID=
YC_FOLDER_ID=
YANDEX_SEARCH_API_KEY=
YANDEX_SEARCH_FOLDER_ID=

# Maps
YANDEX_MAPS_API_KEY=
YANDEX_MAPS_STATIC_API_KEY=

# Gateway controls
ULTIMATE_ENABLE_MODULES=
ULTIMATE_DISABLE_MODULES=
ULTIMATE_PREFIX_TOOLS=0
ULTIMATE_CHILD_TIMEOUT_MS=20000
