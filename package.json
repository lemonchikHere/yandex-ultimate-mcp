{
  "name": "yandex-ultimate-mcp",
  "version": "0.1.0",
  "description": "RU-first ultimate MCP gateway for Yandex APIs: Direct, Metrika, Webmaster, Tracker, Cloud, Maps and Search.",
  "main": "dist/src/cli.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "start": "node dist/src/cli.js serve",
    "doctor": "node dist/src/cli.js doctor",
    "auth": "node dist/src/cli.js auth",
    "modules": "node dist/src/cli.js modules",
    "smoke": "npm run build && node scripts/smoke.mjs",
    "test": "npm run smoke",
    "audit": "npm audit --audit-level=high",
    "prepare": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "yandex",
    "yandex-direct",
    "yandex-metrika",
    "yandex-webmaster",
    "yandex-cloud",
    "yandex-maps",
    "yandex-tracker"
  ],
  "author": "",
  "license": "MIT",
  "type": "module",
  "bin": {
    "yandex-ultimate-mcp": "dist/src/cli.js",
    "yandex-ultimate": "dist/src/cli.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.2",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  },
  "files": [
    "dist",
    "README.md",
    "docs",
    "assets",
    "LICENSE",
    "THIRD_PARTY_NOTICES.md",
    ".env.example"
  ],
  "engines": {
    "node": ">=20"
  }
}
